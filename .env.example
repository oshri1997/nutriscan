# NutriSnap Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# Gemini API Key (AI food scanning)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# RevenueCat API Key (subscription management)
# Get from: RevenueCat Dashboard > Project Settings > API Keys
REVENUECAT_API_KEY=your_revenuecat_api_key_here
