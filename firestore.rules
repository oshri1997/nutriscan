rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // User documents: only the authenticated user can read/write their own document
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);

      // Meal logs subcollection: only the owning user can access their meal logs
      match /meal_logs/{mealId} {
        allow read, write: if isOwner(uid);
      }

      // Scan events subcollection: only the owning user can access their scan events
      match /scan_events/{eventId} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}
